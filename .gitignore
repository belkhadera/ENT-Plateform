# Dependencies
node_modules/
*/node_modules/
**/node_modules/

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
**/.env

# MinIO data
data/minio/
data/minio-data/

# Ollama data
data/ollama/

# PostgreSQL data
data/postgres-keycloak/

# Redis data
data/redis/

# Scripts
scripts/

# Diagrams (keep folder but ignore generated files)
diagrams/*.py
diagrams/*.png
!diagrams/README.md

# Documentation
docs/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*/dist/
*/build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Database
*.db
*.sqlite
*.sqlite3

# Docker
.dockerignore

# Uploads and temporary files
uploads/
temp/
tmp/
*.tmp

# SSH keys
*.pem
*.pub
id_ed25519*

# Keycloak
keycloak/data/

# Backend service specific
backend/services/*/uploads/
backend/services/*/logs/
backend/services/*/node_modules/

# Frontend specific
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Kubernetes secrets
infrastructure/kubernetes/secrets/

# Terraform
*.tfstate
.terraform/

# Python cache (for diagram scripts)
__pycache__/
*.pyc
*.pyo

# Jupyter notebooks
*.ipynb_checkpoints/

# Lock files (keep package-lock.json but ignore others)
**/package-lock.json
!package-lock.json
**/yarn.lock

# Backup files
*.bak
*.backup
*~

# Additional exclusions
*.tgz
*.tar.gz
*.zip
*.rar

# Configuration files (keep examples)
*.conf
*.config
!*.example
